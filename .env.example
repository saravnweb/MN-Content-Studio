# Supabase — get from https://app.supabase.com > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google OAuth (optional — for Google One Tap)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Web Push / VAPID — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_MAILTO=mailto:you@yourdomain.com

# YouTube Data API v3 — get from https://console.cloud.google.com > APIs & Services > Credentials
# Required for auto-fetching subscriber counts during creator onboarding
YOUTUBE_API_KEY=your-youtube-data-api-key

# Internal API secret — any strong random string
INTERNAL_API_SECRET=your-random-secret
